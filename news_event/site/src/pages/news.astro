---
import Base from '../layouts/Base.astro';
import NewsCard from '../components/NewsCard.astro';

import newsData from '../data/news.json';

const news = newsData as any[];

// Group by category for filter counts
const categories = ['all', 'unlisted', 'ipo', 'company', 'gmp'];
const categoryCounts: Record<string, number> = { all: news.length };
for (const article of news) {
  const cat = article.category || 'other';
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
}
---

<Base title="News - UnlistedPulse">
  <h1 class="text-2xl font-bold text-gray-900 mb-4">All News</h1>

  <!-- Category filters (client-side) -->
  <div class="flex flex-wrap gap-2 mb-6" id="filters">
    {categories.map((cat) => (
      <button
        data-category={cat}
        class={`px-3 py-1.5 rounded-full text-sm font-medium border transition-all ${
          cat === 'all'
            ? 'bg-gray-900 text-white border-gray-900'
            : 'bg-white text-gray-600 border-gray-200 hover:border-gray-300'
        }`}
      >
        {cat.charAt(0).toUpperCase() + cat.slice(1)}
        <span class="ml-1 text-xs opacity-70">{categoryCounts[cat] || 0}</span>
      </button>
    ))}
  </div>

  <div class="space-y-2" id="news-list">
    {news.map((article) => (
      <div data-category={article.category}>
        <NewsCard article={article} />
      </div>
    ))}
  </div>

  {news.length === 0 && (
    <p class="text-center text-gray-500 py-12">No news articles yet. Run the scrapers first.</p>
  )}
</Base>

<script>
  const filters = document.getElementById('filters');
  const items = document.querySelectorAll('#news-list > div');

  filters?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;

    const category = btn.dataset.category;

    // Update button styles
    filters.querySelectorAll('button').forEach((b) => {
      b.className = 'px-3 py-1.5 rounded-full text-sm font-medium border transition-all bg-white text-gray-600 border-gray-200 hover:border-gray-300';
    });
    btn.className = 'px-3 py-1.5 rounded-full text-sm font-medium border transition-all bg-gray-900 text-white border-gray-900';

    // Filter items
    items.forEach((item) => {
      const el = item as HTMLElement;
      if (category === 'all' || el.dataset.category === category) {
        el.style.display = '';
      } else {
        el.style.display = 'none';
      }
    });
  });
</script>
