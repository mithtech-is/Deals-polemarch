---
import Base from '../../layouts/Base.astro';
import NewsCard from '../../components/NewsCard.astro';
import newsData from '../../data/news.json';

import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';

const configPath = path.resolve(process.cwd(), '..', 'config', 'companies.yml');
const configText = fs.readFileSync(configPath, 'utf-8');
const config = yaml.load(configText) as any;
const companies = config.companies;

export async function getStaticPaths() {
  const fs = await import('node:fs');
  const path = await import('node:path');
  const yaml = (await import('js-yaml')).default;

  const configPath = path.resolve(process.cwd(), '..', 'config', 'companies.yml');
  const configText = fs.readFileSync(configPath, 'utf-8');
  const config = yaml.load(configText) as any;

  return config.companies.map((company: any) => ({
    params: { slug: company.slug },
    props: { company },
  }));
}

const news = newsData as any[];
const { slug } = Astro.params;
const { company } = Astro.props as { company: any };

const companyNews = news.filter((a: any) => a.company_slug === slug);
---

<Base title={`${company.name} - UnlistedPulse`}>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-600 hover:underline">&larr; Dashboard</a>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">{company.name}</h1>
    <div class="flex items-center gap-3 mt-2 text-sm text-gray-500">
      <span>ISIN: <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">{company.isin}</code></span>
      {company.aliases && (
        <span>Also known as: {company.aliases.join(', ')}</span>
      )}
    </div>
  </div>

  <h2 class="text-lg font-bold text-gray-900 mb-3">
    News
    <span class="text-sm font-normal text-gray-500 ml-1">({companyNews.length} articles)</span>
  </h2>

  <div class="space-y-2">
    {companyNews.map((article: any) => (
      <NewsCard article={article} />
    ))}
  </div>

  {companyNews.length === 0 && (
    <p class="text-center text-gray-500 py-12">No news articles found for {company.name}</p>
  )}
</Base>
