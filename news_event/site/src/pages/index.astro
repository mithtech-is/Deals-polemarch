---
import Base from '../layouts/Base.astro';
import NewsCard from '../components/NewsCard.astro';
import DRHPTable from '../components/DRHPTable.astro';
import GMPTable from '../components/GMPTable.astro';
import TrendingCompanies from '../components/TrendingCompanies.astro';

import newsData from '../data/news.json';
import drhpData from '../data/drhp_filings.json';
import gmpData from '../data/gmp.json';
import metaData from '../data/meta.json';

const news = newsData as any[];
const drhp = drhpData as any[];
const gmpEntries = gmpData as any[];
const meta = metaData as any;
---

<Base title="UnlistedPulse - Dashboard">
  <!-- Trending Companies -->
  <section class="mb-8">
    <h2 class="text-lg font-bold text-gray-900 mb-3">Trending Companies</h2>
    <TrendingCompanies articles={news} />
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Latest News (2/3 width) -->
    <div class="lg:col-span-2">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-bold text-gray-900">Latest News</h2>
        <a href="/news" class="text-sm text-blue-600 hover:underline">View all</a>
      </div>
      <div class="space-y-2">
        {news.slice(0, 15).map((article) => (
          <NewsCard article={article} />
        ))}
      </div>
    </div>

    <!-- Sidebar (1/3 width) -->
    <div class="space-y-6">
      <!-- DRHP Tracker -->
      <div class="bg-white rounded-lg border border-gray-200 p-4">
        <h2 class="text-lg font-bold text-gray-900 mb-3">DRHP Filings</h2>
        <DRHPTable filings={drhp} limit={10} />
      </div>

      <!-- GMP Watch -->
      <div class="bg-white rounded-lg border border-gray-200 p-4">
        <h2 class="text-lg font-bold text-gray-900 mb-3">GMP Watch</h2>
        <GMPTable entries={gmpEntries} />
      </div>

      <!-- Last Updated -->
      {meta.finished_at && (
        <p class="text-xs text-gray-400 text-center">
          Last updated: {new Date(meta.finished_at).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' })}
        </p>
      )}
    </div>
  </div>
</Base>
