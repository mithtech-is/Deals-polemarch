---
interface Props {
  articles: Array<{
    company_name: string | null;
    company_slug: string | null;
    isin: string | null;
  }>;
}

const { articles } = Astro.props;

// Count mentions per company
const counts = new Map<string, { name: string; slug: string; count: number }>();
for (const article of articles) {
  if (article.company_name && article.company_slug) {
    const existing = counts.get(article.company_slug);
    if (existing) {
      existing.count++;
    } else {
      counts.set(article.company_slug, {
        name: article.company_name,
        slug: article.company_slug,
        count: 1,
      });
    }
  }
}

const trending = Array.from(counts.values())
  .sort((a, b) => b.count - a.count)
  .slice(0, 10);
---

<div class="flex flex-wrap gap-2">
  {trending.map((company) => (
    <a
      href={`/company/${company.slug}`}
      class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 rounded-full text-sm hover:border-blue-300 hover:bg-blue-50 transition-all"
    >
      <span class="font-medium text-gray-900">{company.name}</span>
      <span class="text-xs text-gray-500 bg-gray-100 px-1.5 py-0.5 rounded-full">
        {company.count}
      </span>
    </a>
  ))}
  {trending.length === 0 && (
    <p class="text-sm text-gray-500">No company mentions yet</p>
  )}
</div>
