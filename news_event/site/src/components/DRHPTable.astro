---
interface Props {
  filings: Array<{
    company: string;
    isin: string | null;
    filed_date: string;
    doc_type: string;
    status: string;
    drhp_url: string;
  }>;
  limit?: number;
}

const { filings, limit } = Astro.props;
const displayFilings = limit ? filings.slice(0, limit) : filings;

const statusColors: Record<string, string> = {
  'DRHP Filed': 'bg-blue-100 text-blue-700',
  'RHP Filed': 'bg-green-100 text-green-700',
  'Other Document': 'bg-gray-100 text-gray-600',
};
---

<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200 text-left text-xs text-gray-500 uppercase tracking-wider">
        <th class="py-2 pr-4">Company</th>
        <th class="py-2 pr-4">Date</th>
        <th class="py-2 pr-4">Status</th>
        <th class="py-2">Document</th>
      </tr>
    </thead>
    <tbody>
      {displayFilings.map((filing) => (
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="py-2.5 pr-4 font-medium text-gray-900">{filing.company}</td>
          <td class="py-2.5 pr-4 text-gray-600">{filing.filed_date}</td>
          <td class="py-2.5 pr-4">
            <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[filing.status] || 'bg-gray-100 text-gray-600'}`}>
              {filing.status}
            </span>
          </td>
          <td class="py-2.5">
            {filing.drhp_url ? (
              <a href={filing.drhp_url} target="_blank" rel="noopener" class="text-blue-600 hover:underline text-xs">
                View
              </a>
            ) : (
              <span class="text-gray-400 text-xs">-</span>
            )}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
  {displayFilings.length === 0 && (
    <p class="text-center text-gray-500 py-8 text-sm">No DRHP filings found</p>
  )}
</div>
