---
interface Props {
  article: {
    id: string;
    title: string;
    url: string;
    source: string;
    published_at: string;
    category: string;
    isin: string | null;
    company_name: string | null;
    company_slug: string | null;
    snippet: string;
    summary?: string;
  };
}

const { article } = Astro.props;

function timeAgo(dateStr: string): string {
  const now = new Date();
  const date = new Date(dateStr);
  const diffMs = now.getTime() - date.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  if (diffMins < 60) return `${diffMins}m ago`;
  const diffHours = Math.floor(diffMins / 60);
  if (diffHours < 24) return `${diffHours}h ago`;
  const diffDays = Math.floor(diffHours / 24);
  return `${diffDays}d ago`;
}

const categoryColors: Record<string, string> = {
  unlisted: 'bg-purple-100 text-purple-700',
  ipo: 'bg-blue-100 text-blue-700',
  company: 'bg-green-100 text-green-700',
  gmp: 'bg-amber-100 text-amber-700',
};

const badgeClass = categoryColors[article.category] || 'bg-gray-100 text-gray-700';
---

<a href={article.url} target="_blank" rel="noopener" class="block bg-white rounded-lg border border-gray-200 p-4 hover:border-gray-300 hover:shadow-sm transition-all">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <h3 class="text-sm font-semibold text-gray-900 leading-snug line-clamp-2">
        {article.title}
      </h3>
      {article.summary ? (
        <p class="text-xs text-gray-600 mt-1 line-clamp-2">{article.summary}</p>
      ) : article.snippet ? (
        <p class="text-xs text-gray-500 mt-1 line-clamp-1">{article.snippet}</p>
      ) : null}
      <div class="flex items-center gap-2 mt-2 text-xs text-gray-500">
        {article.source && <span>{article.source}</span>}
        <span>&middot;</span>
        <span>{timeAgo(article.published_at)}</span>
        <span class={`px-1.5 py-0.5 rounded text-[10px] font-medium ${badgeClass}`}>
          {article.category}
        </span>
        {article.company_name && article.company_slug && (
          <a href={`/company/${article.company_slug}`} class="text-blue-600 hover:underline" onclick="event.stopPropagation()">
            {article.company_name}
          </a>
        )}
      </div>
    </div>
  </div>
</a>
